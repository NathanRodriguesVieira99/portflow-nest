{
  "title": "Microservices - NestJs",
  "uid": "microservice-nodejs",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "tags": ["nestjs", "microservices"],
  "panels": [
    {
      "id": 10,
      "title": "Requests per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "HTTP Status Codes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by(status) (rate(http_requests_total{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "HTTP Methods",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by(method) (rate(http_requests_total{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{ method }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Request Duration (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 1,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(process_cpu_user_seconds_total{job=~\"$job\"}[$__rate_interval]) * 100",
          "legendFormat": "User",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_system_seconds_total{job=~\"$job\"}[$__rate_interval]) * 100",
          "legendFormat": "System",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=~\"$job\"}",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "expr": "process_virtual_memory_bytes{job=~\"$job\"}",
          "legendFormat": "Virtual",
          "refId": "B"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=~\"$job\"}",
          "legendFormat": "Heap Used",
          "refId": "C"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=~\"$job\"}",
          "legendFormat": "Heap Total",
          "refId": "D"
        }
      ]
    },
    {
      "id": 3,
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{job=~\"$job\"}",
          "legendFormat": "Lag",
          "refId": "A"
        },
        {
          "expr": "nodejs_eventloop_lag_p50_seconds{job=~\"$job\"}",
          "legendFormat": "p50",
          "refId": "B"
        },
        {
          "expr": "nodejs_eventloop_lag_p99_seconds{job=~\"$job\"}",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Handles & Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "nodejs_active_handles{job=~\"$job\"}",
          "legendFormat": "Handles",
          "refId": "A"
        },
        {
          "expr": "nodejs_active_requests{job=~\"$job\"}",
          "legendFormat": "Requests",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Heap Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "showPoints": "never", "spanNulls": true },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "nodejs_external_memory_bytes{job=~\"$job\"}",
          "legendFormat": "External",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_space_size_total_bytes{job=~\"$job\"}",
          "legendFormat": "Heap Space Total",
          "refId": "B"
        },
        {
          "expr": "nodejs_heap_space_size_used_bytes{job=~\"$job\"}",
          "legendFormat": "Heap Space Used",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "GC Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum{job=~\"$job\"}[$__rate_interval])",
          "legendFormat": "GC Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Log Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "custom": { "showPoints": "never", "spanNulls": true } }
      },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by(level) (rate({$log_label=\"$log_value\"} |= `` [$__auto]))",
          "legendFormat": "{{ level }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Log Levels",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        }
      },
      "options": {
        "displayLabels": ["percent", "name"],
        "legend": { "showLegend": true, "placement": "right" },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum by(level) (count_over_time({$log_label=\"$log_value\"} [$__auto]))",
          "legendFormat": "{{ level }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Recent Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{$log_label=\"$log_value\"} |= ``",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "label": "Prometheus Job",
        "query": "label_values(up, job)",
        "refresh": 1,
        "current": {
          "selected": true,
          "text": "container-service-metrics",
          "value": "container-service-metrics"
        },
        "sort": 1,
        "hide": 0
      },
      {
        "name": "log_label",
        "type": "custom",
        "label": "Log Label",
        "query": "service,container",
        "current": { "selected": true, "text": "service", "value": "service" },
        "hide": 0
      },
      {
        "name": "log_value",
        "type": "textbox",
        "label": "Log Value",
        "query": "container-service",
        "current": {
          "selected": true,
          "text": "container-service",
          "value": "container-service"
        },
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" }
}
