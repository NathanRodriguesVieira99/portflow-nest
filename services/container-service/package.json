{
  "name": "container-service",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch ",
    "start:debug": "nest start --debug --watch ",
    "start:prod": "node --require ./dist/tracing.js dist/main",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test:unit": "dotenv -e .env.test -- vitest run --project unit --reporter verbose",
    "test:unit:watch": "dotenv -e .env.test -- vitest --project unit --watch",
    "test:unit:cov": "dotenv -e .env.test -- vitest run --project unit --coverage ",
    "pretest:int": " dotenv -e .env.test prisma migrate deploy",
    "test:int": "dotenv -e .env.test -- vitest run --project integration --reporter verbose",
    "test:int:cov": "dotenv -e .env.test -- vitest run --project integration --coverage",
    "pretest:e2e": " dotenv -e .env.test prisma migrate deploy",
    "test:e2e": "dotenv -e .env.test -- vitest run --project e2e --reporter verbose",
    "test:all": "dotenv -e .env.test -- vitest --run",
    "test:ci": "dotenv -e .env.test -- vitest --run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "pnpm prisma db seed"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/platform-express": "^11.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-express": "^0.67.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-kafkajs": "^0.28.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.65.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/instrumentation": "^7.8.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "axios": "^1.18.0",
    "cache-manager": "^7.2.8",
    "dotenv": "^17.4.2",
    "kafkajs": "^2.2.4",
    "nestjs-cls": "^6.2.1",
    "nestjs-pino": "^4.6.1",
    "opossum": "^9.0.0",
    "pg": "^8.21.0",
    "pino-http": "^11.0.0",
    "pino-loki": "^3.0.0",
    "prom-client": "^15.1.3",
    "redis": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "protobufjs"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.4.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
