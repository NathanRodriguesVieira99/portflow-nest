    "test:unit:watch": "NODE_ENV=test vitest --project unit --watch",
    "test:unit:cov": "NODE_ENV=test vitest --project unit --coverage",
    "test:integration": "NODE_ENV=test vitest --project integration",
    "test:e2e": "NODE_ENV=test vitest --project e2e",
    "test:all": "NODE_ENV=test vitest --run",
    "test:ci": "NODE_ENV=test vitest --run --coverage",
    "test:cov": "NODE_ENV=test vitest --run --coverage --project unit --project integration",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "pnpm prisma db seed"
